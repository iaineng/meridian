FROM debian:13

# Pre-baked base image for deploy-vm.sh
# Contains: system packages, Bun, claude user
# Does NOT contain: Claude Code CLI, project files

ENV DEBIAN_FRONTEND=noninteractive

# System packages
RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends \
       curl git build-essential ca-certificates gnupg unzip procps \
    && rm -rf /var/lib/apt/lists/*

# Bun (sole runtime — no Node.js)
RUN curl -fsSL https://bun.sh/install | bash \
    && cp /root/.bun/bin/bun /usr/local/bin/bun \
    && chmod +x /usr/local/bin/bun

# Remove default ubuntu user (uid 1000) and create claude user
RUN if getent passwd 1000 > /dev/null 2>&1; then \
      userdel -r "$(getent passwd 1000 | cut -d: -f1)" 2>/dev/null || true; \
    fi \
    && useradd -m -u 1000 -s /bin/bash claude \
    && mkdir -p /home/claude/.claude /home/claude/.cache/meridian \
    && chown -R claude:claude /home/claude
