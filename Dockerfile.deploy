# Self-contained deployment Dockerfile.
# Installs Claude Code via npm so the host machine does not need
# Claude installed.
#
# Usage:
#   docker build -f Dockerfile.deploy -t claude-max-proxy .
#   ./bin/deploy.sh          (recommended — handles auth + run)

# ---- Build stage ----
FROM oven/bun:1 AS build

WORKDIR /app
COPY package.json bun.lock* ./
RUN --mount=type=cache,target=/root/.bun \
    bun install

COPY tsconfig.json* ./
COPY bin/ ./bin/
COPY src/ ./src/
RUN rm -rf dist && bun build bin/cli.ts src/proxy/server.ts --outdir dist --target node --splitting --external @anthropic-ai/claude-agent-sdk --external @node-rs/xxhash --entry-naming '[name].js'

# ---- Runtime stage ----
FROM node:22-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN userdel -r node 2>/dev/null; \
    groupdel node 2>/dev/null; \
    useradd -m -u 1000 -s /bin/bash claude \
    && mkdir -p /home/claude/.claude /home/claude/.cache/meridian \
    && chown -R claude:claude /home/claude

# Install Claude Code via npm
RUN npm install -g @anthropic-ai/claude-code@2.1.90

WORKDIR /app

# Copy built proxy artifacts
USER root
COPY --from=build --chown=claude:claude /app/node_modules ./node_modules
COPY --from=build --chown=claude:claude /app/dist ./dist
COPY --from=build --chown=claude:claude /app/package.json ./
COPY --chown=claude:claude bin/docker-entrypoint.sh bin/claude-proxy-supervisor.sh ./bin/
RUN sed -i 's/\r$//' ./bin/docker-entrypoint.sh ./bin/claude-proxy-supervisor.sh \
    && chmod +x ./bin/docker-entrypoint.sh ./bin/claude-proxy-supervisor.sh

USER claude

EXPOSE 3456

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD node -e "const r=await fetch('http://127.0.0.1:3456/health');process.exit(r.ok?0:1)"

ENV MERIDIAN_PASSTHROUGH=1 \
    MERIDIAN_HOST=0.0.0.0 \
    MERIDIAN_MAX_CONCURRENT=10 \
    MERIDIAN_SONNET_MODEL=sonnet \
    MERIDIAN_WORKDIR=/app \
    MERIDIAN_NO_FILE_CHANGES=1

ENTRYPOINT ["./bin/docker-entrypoint.sh"]
CMD ["./bin/claude-proxy-supervisor.sh"]
